{
  "siteUrl": "https://www.gethoneydew.app",
  "appLinks": {
    "web": "https://app.gethoneydew.app/",
    "ios": "https://apps.apple.com/us/app/honeydew-family-calendar/id6752225362",
    "android": "https://play.google.com/store/apps/details?id=app.gethoneydew.honeydew"
  },
  "directories": {
    "publicBlog": "public/blog",
    "scheduledBlog": "blog/scheduled",
    "reports": "reports/website-manager"
  },
  "blogChecks": {
    "requiredFrontmatter": [
      "title",
      "slug",
      "description",
      "coverImage",
      "keywords",
      "category",
      "featured",
      "author",
      "publishDate"
    ],
    "requireQuickAnswer": true,
    "quickAnswerPatterns": ["quick answer", "quick answer:"],
    "requireTable": true,
    "requireFAQ": true,
    "faqPatterns": ["faq", "frequently asked questions"],
    "requireTikTokIdeas": true,
    "tiktokPatterns": ["tiktok"],
    "requireCTA": true,
    "ctaPatterns": [
      "app.gethoneydew.app",
      "apps.apple.com/us/app/honeydew-family-calendar/id6752225362"
    ],
    "requireAppStoreLink": true,
    "appStoreLinkUrl": "https://apps.apple.com/us/app/honeydew-family-calendar/id6752225362",
    "appStoreLinkHighPriorityCategories": ["Comparison", "Review", "Guide"],
    "staleAppStoreIds": ["id1546892037", "id6475768439"],
    "forbiddenCtaPatterns": [
      "Try Honeydew Free",
      "Try Honeydew free",
      "Start Your Free Trial",
      "Start Free Trial"
    ],
    "stalePricingPatterns": [
      "$9.99",
      "$99/yr",
      "$99/year",
      "$99 per year"
    ],
    "requireInternalLinks": true,
    "internalLinkHost": "https://www.gethoneydew.app",
    "minWordCount": 2000
  },
  "pageCtaChecks": [
    {
      "path": "src/components/Hero.tsx",
      "requiredPatterns": ["DownloadCTA", "Try Honeydew on the App Store"]
    },
    {
      "path": "src/components/CallToAction.tsx",
      "requiredPatterns": ["DownloadCTA", "Get Honeydew on the App Store"]
    },
    {
      "path": "src/components/Navbar.tsx",
      "requiredPatterns": ["getPrimaryDownloadDestination", "Get the App"]
    },
    {
      "path": "src/components/Footer.tsx",
      "requiredPatterns": ["AppStoreBadge"]
    },
    {
      "path": "src/pages/BlogPostPage.tsx",
      "requiredPatterns": ["DownloadCTA", "buildBlogCTALink", "Try Honeydew on the App Store"]
    },
    {
      "path": "src/pages/WhyHoneydewPage.tsx",
      "requiredPatterns": ["AppStoreBadge"]
    }
  ],
  "selfImprovement": {
    "issueCarryoverThreshold": 2,
    "focusDecayDays": 14
  }
}
